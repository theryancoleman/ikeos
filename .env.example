# Path to your Obsidian vault (or any vault-structured directory) on the host
VAULT_PATH=/path/to/your/obsidian-vault

# Path to your Claude Code VERSION file on the host (e.g. ~/.claude/VERSION)
CLAUDE_VERSION_PATH=/path/to/.claude/VERSION

# Host directory for metrics events (events.jsonl written here by the app)
METRICS_PATH_HOST=/path/to/.claude/metrics

# Secret key for Flask session signing — use any long random string
FLASK_SECRET_KEY=change-me

# Token protecting vault mutation endpoints (POST /capture, PATCH /entries)
# Use any secret string — treat it like a password
CAPTURE_TOKEN=your-capture-token-here

# URL of the Claude Code session manager service (advanced — only needed for Sessions tab)
SESSION_MANAGER_URL=http://host.docker.internal:5010

# Host path to the project directory housekeeping runs against (advanced)
HOUSEKEEPING_PROJECT_DIR=/path/to/your/project-dir

# Host path to the aios-blog content/posts directory (for blog draft status widget)
AIOS_BLOG_POSTS_PATH=/path/to/aios-blog/content/posts
