# Path to your Obsidian vault (or any vault-structured directory) on the host
VAULT_PATH=/path/to/your/obsidian-vault

# Project slug used for housekeeping/capabilities/schedule paths in the vault (default: claude-config)
PLATFORM_PROJECT_SLUG=claude-config

# Path to the deployed agent-config VERSION file on the host (leave blank to disable the badge)
CLAUDE_VERSION_PATH=/path/to/.claude/VERSION

# Host directory for metrics events (events.jsonl written here by the app)
METRICS_PATH_HOST=/path/to/.claude/metrics

# Secret key for Flask session signing — use any long random string
FLASK_SECRET_KEY=change-me

# Token protecting vault mutation endpoints (POST /capture, PATCH /entries)
# Use any secret string — treat it like a password
CAPTURE_TOKEN=your-capture-token-here

# URL of the Claude Code session manager service (advanced — only needed for Sessions tab)
SESSION_MANAGER_URL=http://host.docker.internal:5010

# Host path to the project directory housekeeping runs against (advanced)
HOUSEKEEPING_PROJECT_DIR=/path/to/your/project-dir

# Host path to the aios-blog content/posts directory (mounted rw for blog draft editing)
AIOS_BLOG_POSTS_PATH=/path/to/aios-blog/content/posts
# WSL/host path to the aios-blog project root (used as project_dir for publish/rewrite sessions)
AIOS_BLOG_PROJECT_DIR=/path/to/aios-blog
# Host path to the directory where platform review Markdown files are written
# The platform-review-narrative housekeeping task writes YYYY-MM-DD-review.md files here
WEEKLY_REVIEW_OUTPUT_PATH=/path/to/claude-config/docs/platform-reviews
# Note: on Windows/WSL2 hosts, volume-mount paths use Windows format (e.g. C:\Server\claude-config\docs\platform-reviews) — see other *_PATH vars above
# Bluesky handle for the Publishing tab social panel (e.g. ikeos.bsky.social)
BLUESKY_HANDLE=

# Host path to the claude-config root directory (enables reflection health widget on dashboard)
# The app reads library/weak-signals.json and library/metrics.json from this directory.
# Leave blank to disable the widget — the dashboard degrades gracefully.
CLAUDE_CONFIG_PATH=/path/to/claude-config
